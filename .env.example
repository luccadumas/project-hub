# Database
POSTGRES_DB=project_hub
POSTGRES_USER=project_hub
POSTGRES_PASSWORD=project_hub
DB_HOST_PORT=5435

# Backend
SPRING_DATASOURCE_URL=jdbc:postgresql://project-hub-db:5432/project_hub
SPRING_DATASOURCE_USERNAME=project_hub
SPRING_DATASOURCE_PASSWORD=project_hub
SERVER_PORT=8080
API_HOST_PORT=8090
EXTERNAL_MEMBERS_BASE_URL=http://project-hub-api:8080
PROJECT_HUB_CORS_ALLOWED_ORIGINS=http://localhost:5190
# JWT
PROJECT_HUB_JWT_SECRET=change-me-to-a-secure-secret-at-least-32-characters-long
PROJECT_HUB_JWT_ACCESS_EXPIRATION_MINUTES=15
PROJECT_HUB_JWT_REFRESH_EXPIRATION_DAYS=7

# Producao: admin inicial (opcional, so roda se app_users estiver vazio)
# PROJECT_HUB_BOOTSTRAP_ADMIN_USERNAME=ops-admin
# PROJECT_HUB_BOOTSTRAP_ADMIN_PASSWORD=

HIBERNATE_FORMAT_SQL=false

# Frontend build
VITE_API_URL=http://localhost:8090
WEB_HOST_PORT=5190
